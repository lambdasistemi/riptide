set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

lint:
    npm ci
    npm run build

build:
    npm run build
    spago bundle --module Main
    mv index.js dist/index.js

test:
    spago test

serve port="4173":
    test -f dist/index.html
    test -f dist/index.js
    node -e 'const fs = require("node:fs"); const http = require("node:http"); const path = require("node:path"); const root = path.resolve("dist"); const types = { ".css": "text/css; charset=utf-8", ".html": "text/html; charset=utf-8", ".js": "text/javascript; charset=utf-8", ".json": "application/json; charset=utf-8", ".svg": "image/svg+xml" }; const server = http.createServer((req, res) => { const url = new URL(req.url, "http://localhost"); const name = decodeURIComponent(url.pathname === "/" ? "/index.html" : url.pathname); const file = path.resolve(root, "." + name); if (!file.startsWith(root + path.sep) && file !== root) { res.writeHead(403).end("Forbidden"); return; } fs.readFile(file, (err, body) => { if (err) { res.writeHead(404).end("Not found"); return; } const html = path.basename(file) === "index.html"; res.writeHead(200, { "Content-Type": types[path.extname(file)] || "application/octet-stream" }); res.end(html ? body.toString("utf8").replace("../src/bootstrap.js", "./index.js") : body); }); }); server.listen(Number(process.argv[1]), "127.0.0.1", () => console.log(`serving dist on http://127.0.0.1:${process.argv[1]}`));' {{port}}

dev port="4173": build
    just serve {{port}}
